# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
DEBUG=True

# MongoDB
MONGO_URI=mongodb://localhost:27017/subspace_db
MONGO_DB_NAME=subspace_db

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# SendGrid / Email
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@subspace.com
EMAIL_FROM_NAME=Subspace Platform

# Twilio / SMS
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redis
REDIS_URL=redis://localhost:6379/0

# App
FRONTEND_URL=http://localhost:5500
BACKEND_URL=http://localhost:5000
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Admin
ADMIN_EMAIL=admin@subspace.com
ADMIN_PASSWORD=Admin@123456

# AI Matching
AI_MATCH_ALGORITHM=cosine_similarity
MAX_NEARBY_DISTANCE_KM=50
